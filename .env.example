DJANGO_SECRET_KEY=replace-this
DJANGO_DEBUG=1
DJANGO_LOG_LEVEL=INFO
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

APP_ENABLE_ONLINE_SEARCH=1
APP_WEB_SEARCH_TIMEOUT=8
APP_CASE_DB_PATH=./cncdoctor/runtime/fault_cases.sqlite3
APP_CASE_SQL_SEED=./data/seeds/fault_cases.sql
APP_DEMO_DIR=./cncdoctor/demo

APP_CORS_ALLOW_ORIGIN=*
APP_CORS_ALLOW_METHODS=GET,POST,OPTIONS
APP_CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

APP_NEO4J_URI=http://127.0.0.1:7474
APP_NEO4J_USER=neo4j
APP_NEO4J_PASSWORD=replace-this
